#!/bin/bash
# Shared database helper functions. Source this file, do not execute it.

# Drop and recreate a local PostgreSQL database.
# Terminates any existing connections before dropping.
# Usage: drop_and_recreate_db <db_name> <owner>
drop_and_recreate_db() {
  local DB_NAME=$1
  local DB_OWNER=$2

  cat << EOF > /tmp/drop_db
\c postgres
SELECT pg_terminate_backend(pid)
FROM pg_stat_activity
WHERE datname = '$DB_NAME';
DROP DATABASE IF EXISTS $DB_NAME;
CREATE DATABASE $DB_NAME WITH OWNER $DB_OWNER;
EOF

  psql < /tmp/drop_db
}
