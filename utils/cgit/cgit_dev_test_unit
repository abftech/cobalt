#!/bin/bash

# about: runs unit tests
# Call with -c or --coverage to include coverage output
# Call with -w N or --workers N to run in parallel (default: 4)

# Variables
export RDS_DB_NAME=test

# Get arguments
COVERAGE=0
WORKERS=4

while [[ $# -gt 0 ]]; do
  case $1 in
    -c|--coverage)
      COVERAGE=1
      shift # past argument
      ;;
    -w|--workers)
      WORKERS="$2"
      shift 2
      ;;
    -*|--*)
      echo "Unknown option $1"
      exit 1
      ;;
  esac
done

_cgit_test_handle_db

# Only run coverage if called by the wrapper script
if [ $COVERAGE -eq 1 ]
then
  coverage run -p ./manage.py run_tests_unit --workers $WORKERS
else
  ./manage.py run_tests_unit --workers $WORKERS
fi
