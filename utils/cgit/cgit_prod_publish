#!/bin/bash

# about: release to production

BRANCH=$(git branch --show-current)

if [[ $BRANCH != *"release"* ]]; then
  echo "You are not on a release branch. Change to a release branch to perform this function."
  exit 1
fi

clear
echo "*************** PRODUCTION RELEASE ABOUT TO HAPPEN *********************"
echo ""
echo ""
echo "Congratulations on being ready to release to production."
echo ""
echo "I will check out the release branch $BRANCH and sync develop and master,"
echo "then deploy to PRODUCTION."
echo ""
echo ""
read -p "Press key to continue..." -n1 -s

if [[ -z $(git status -s) ]]
then
  echo ""
  echo ""
  echo "Pulling latest $BRANCH branch..."
  echo ""

  git pull origin $BRANCH
  if [ $? -ne 0 ];then
   exit 1
  fi

  echo ""
  echo "Adding release date to release notes..."
  echo ""

  VERSION=${BRANCH#release/}
  python3 << PYEOF
import re
import datetime

release = "$VERSION"
d = datetime.date.today()
suffix = "th" if 11 <= d.day % 100 <= 13 else {1: "st", 2: "nd", 3: "rd"}.get(d.day % 10, "th")
today = f"{d.day}{suffix} {d.strftime('%B %Y')}"

with open("utils/views/release_notes.py") as f:
    content = f.read()

if re.search(r'"release": "' + re.escape(release) + r'",\s*\n\s*"date":', content):
    print(f"Date already set for release {release}")
    exit(0)

pattern = r'("release": "' + re.escape(release) + r'"),'
replacement = r'\1,\n            "date": "' + today + '",'
new_content, count = re.subn(pattern, replacement, content)
if count:
    with open("utils/views/release_notes.py", "w") as f:
        f.write(new_content)
    print(f"Added date {today} to release {release}")
else:
    print(f"WARNING: Release {release} not found in release_notes.py - add the date manually")
PYEOF

  if ! git diff --quiet utils/views/release_notes.py; then
    git add utils/views/release_notes.py
    git commit -m "Add release date to $BRANCH"
    git push origin "$BRANCH"
    if [ $? -ne 0 ];then
      exit 1
    fi
  fi

  echo ""
  echo "Syncing branches before deployment..."
  echo ""

  echo "Checking out develop branch..."
  git checkout develop
  if [ $? -ne 0 ];then
   exit 1
  fi

  echo "Pulling latest develop branch..."
  git pull origin develop
  if [ $? -ne 0 ];then
   exit 1
  fi

  echo "Merging $BRANCH into develop..."
  git merge $BRANCH
  if [ $? -ne 0 ];then
   exit 1
  fi

  echo "Pushing develop..."
  git push origin develop
  if [ $? -ne 0 ];then
   exit 1
  fi

  echo "Checking out master branch..."
  git checkout master
  if [ $? -ne 0 ];then
   exit 1
  fi

  echo "Pulling latest master branch..."
  git pull origin master
  if [ $? -ne 0 ];then
   exit 1
  fi

  echo "Merging $BRANCH into master..."
  git merge $BRANCH
  if [ $? -ne 0 ];then
   exit 1
  fi

  echo "Pushing master branch..."
  git push origin master
  if [ $? -ne 0 ];then
   exit 1
  fi

  echo ""
  echo "Branches synced. Switching back to $BRANCH for deployment..."
  echo ""

  git checkout $BRANCH
  if [ $? -ne 0 ];then
   exit 1
  fi

  echo ""
  echo "Deploying to PRODUCTION server..."
  echo ""

  PRODENV=$(eb list | grep $CGIT_ENV-production)
  PRODNUM=$(eb list | grep $CGIT_ENV-production | wc -l)

  if [ "$PRODNUM" -eq 1 ]
  then
    # Capture current version for rollback hint
    PREV_VERSION=$(aws elasticbeanstalk describe-environments \
      --environment-names "$PRODENV" \
      --query 'Environments[0].VersionLabel' \
      --output text 2>/dev/null)

    # Get number of EC2 instances running. We want at least 2
    utils/cgit/_cgit_scale_environment_for_deployment $PRODENV
    ec2_instances=$?

    echo "Original instance number was $ec2_instances"

    echo "Deploying code to $PRODENV..."
    DATE=$(date '+%a_%d/%m/%Y_%H:%M:%S')
    eb deploy -m "$BRANCH@$DATE" $PRODENV

    if [ "$ec2_instances" = "1" ]
    then
      echo "Restoring instance number to $ec2_instances. Could take a few minutes..."
      eb scale "$ec2_instances" "$PRODENV"
    fi

  else
    echo "Cannot deploy to Production, found more than one Production environment."
    echo $PRODENV
    exit 1
  fi

  echo ""
  echo ""
else
  echo ""
  echo ""
  echo "Cannot comply with request."
  echo "There are uncommitted changes or other problems with your git status. See below."
  echo ""
  echo ""
  git status
  echo ""
  echo ""
  exit 1
fi

echo ""
echo "Running the smoke test..."
cgit_prod_smoke_test

echo ""
echo "Deployment of $BRANCH complete."
if [ -n "$PREV_VERSION" ]; then
  echo ""
  echo "Previous version was: $PREV_VERSION"
  echo "To roll back if needed:"
  echo "  eb deploy -l \"$PREV_VERSION\" $PRODENV"
fi
echo ""
