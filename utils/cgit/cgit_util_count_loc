#!/bin/bash

# about: count lines of code in this branch. Use --html to get output as an HTML table

HTML=$1

# Author identity mappings: normalise old/alternate git identities to canonical names.
# Add entries here if git authors have used multiple names/emails.
# Format: "old_name:canonical_name" — old_name is matched exactly against git blame output.
AUTHOR_ALIASES=(
  "mgu3:Mark Guthrie"
  "Tanmay:Tanmay Dutta"
)

# Apply AUTHOR_ALIASES mappings to each line of stdin
apply_author_aliases() {
  while IFS= read -r name; do
    for alias in "${AUTHOR_ALIASES[@]}"; do
      old="${alias%%:*}"
      new="${alias##*:}"
      if [ "$name" = "$old" ]; then
        name="$new"
        break
      fi
    done
    echo "$name"
  done
}

if [ "$HTML" != "--html" ]; then
  echo ""
  echo "Counts all first-party tracked files (git ls-files)."
  echo "Excluded: static assets, docs/_build, .xml files, migrations, binary files (png, jpg, ico, so, pptx, pdf)."
  echo "Included: Python, HTML templates, RST docs, shell scripts, CSV data, config files, etc."
  echo ""
fi

# Total size of Cobalt - lines of code
TOTAL=$(git ls-files | grep -Ev 'static|_build|.xml|migrations' | xargs wc -l | tail -1 | awk '{print $1}')

# print header
if [ "$HTML" = "--html" ]; then
  echo "<table class='table table-hover table-bordered'>"
  echo "<thead><tr><th>Application<th class='text-end'>Models<th class='text-end'>Functions<th class='text-end'>Templates<th class='text-end'>Lines of Code<th class='text-end'>Percentage<td></tr></thead>"
  echo "<tbody>"

else
  echo ""
  APP_SEP="+----------------------+--------+-----------+-----------+---------------+------------+"
  echo "$APP_SEP"
  printf "| %-20s | %6s | %9s | %9s | %13s | %10s |\n" "Application" "Models" "Functions" "Templates" "Lines of Code" "Percentage"
  echo "$APP_SEP"
fi

# go through dirs (some excluded) and get size of each cobalt app
for DIR in $(ls -d */ | grep -Ev 'static|docs|media|htmlcov|__pycache__')
do
  cd "$DIR"
  NAME=$(echo $DIR | cut -d "/" -f1)
  APP=$(git ls-files | grep -Ev 'static|_build|.xml|migrations' | xargs wc -l | tail -1 | awk '{print $1}')
  FUNCS=$(grep -r --include "*.py" "^def " . | grep -v migrations | wc | awk '{print $1}')
  MODELS=$(grep -r --include "models.py" "^class" . | wc | awk '{print $1}')
  TEMPLATES=$(find . -name "*.html" | grep template | wc | awk '{print $1}')
  APP_FMT=$(printf "%'d\n" $APP)
  PERCENT=$(echo "scale=0; 100 * $APP / $TOTAL" | bc)

  if [ "$HTML" = "--html" ]; then
    echo "<tr><td>$NAME<td class='text-end'>$MODELS<td class='text-end'>$FUNCS<td class='text-end'>$TEMPLATES<td class='text-end'>$APP_FMT<td class='text-end'>$PERCENT<td>"

  else
    printf "| %-20s | %6s | %9s | %9s | %13s | %9s%% | " "$NAME" "$MODELS" "$FUNCS" "$TEMPLATES" "$APP_FMT" "$PERCENT"
  fi

# print * for every percentage
  for i in $(seq $PERCENT); do
    if [ $PERCENT -gt 0 ]; then
       printf "*"
    fi
  done

    if [ "$HTML" = "--html" ]; then
      echo "</tr>"
    fi

  echo ""
  cd ..
done

if [ "$HTML" = "--html" ]; then
  printf "<tr><td colspan='7'><b>Total Lines of Code: %'d</tr>" $TOTAL
else
  echo "$APP_SEP"
  printf "| %-20s | %6s | %9s | %9s | %13s | %10s |\n" "TOTAL" "" "" "" "$(printf "%'d" $TOTAL)" ""
  echo "$APP_SEP"
fi

if [ "$HTML" = "--html" ]; then
    echo "</table>"
else
  DIR_SIZE=$(du -hs . 2>/dev/null | awk '{print $1}')
  GIT_SIZE=$(git ls-files | xargs du -sc 2>/dev/null | tail -1 | awk '{print $1}')
  GIT_SIZE_FMT=$(echo "scale=1; $GIT_SIZE / 1024" | bc)
  echo ""
  echo "Total directory size: $DIR_SIZE  (git-tracked files: ${GIT_SIZE_FMT}MB)"
fi

# Author breakdown via git blame (shows who wrote currently-existing lines)
if [ "$HTML" != "--html" ]; then
  echo ""
  echo "Calculating author breakdown via git blame — this will take 1-2 minutes..."
fi
echo ""
if [ "$HTML" = "--html" ]; then
  echo "<table class='table table-hover table-bordered'>"
  echo "<thead><tr><th>Author<th class='text-end'>Lines<th class='text-end'>Percentage</tr></thead>"
  echo "<tbody>"
else
  AUTH_SEP="+----------------------+----------+------------+"
  echo "$AUTH_SEP"
  printf "| %-20s | %8s | %10s |\n" "Author" "Lines" "Percentage"
  echo "$AUTH_SEP"
fi

BLAME_TOTAL=$(git ls-files | grep -Ev 'static|_build|.xml|migrations' | grep -Ev '\.(png|jpg|ico|so|pptx|pdf)$' \
  | xargs -I{} git blame --line-porcelain {} 2>/dev/null \
  | grep '^author ' \
  | sed 's/^author //' \
  | apply_author_aliases \
  | grep -v 'Not Committed Yet' \
  | sort | uniq -c | sort -rn \
  | awk '{sum += $1} END {print sum}')

git ls-files | grep -Ev 'static|_build|.xml|migrations' | grep -Ev '\.(png|jpg|ico|so|pptx|pdf)$' \
  | xargs -I{} git blame --line-porcelain {} 2>/dev/null \
  | grep '^author ' \
  | sed 's/^author //' \
  | apply_author_aliases \
  | grep -v 'Not Committed Yet' \
  | sort | uniq -c | sort -rn \
  | while read COUNT NAME; do
      PERCENT=$(echo "scale=1; 100 * $COUNT / $BLAME_TOTAL" | bc)
      COUNT_FMT=$(printf "%'d" $COUNT)
      if [ "$HTML" = "--html" ]; then
        echo "<tr><td>$NAME<td class='text-end'>$COUNT_FMT<td class='text-end'>${PERCENT}%</tr>"
      else
        printf "| %-20s | %8s | %9s%% |\n" "$NAME" "$COUNT_FMT" "$PERCENT"
      fi
    done

if [ "$HTML" = "--html" ]; then
  printf "<tr><td><b>Total<td class='text-end'><b>%'d<td></tr>" $BLAME_TOTAL
  echo "</table>"
else
  echo "$AUTH_SEP"
  printf "| %-20s | %8s | %10s |\n" "TOTAL" "$(printf "%'d" $BLAME_TOTAL)" ""
  echo "$AUTH_SEP"
fi